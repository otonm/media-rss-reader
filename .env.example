# Paths
OPML_PATH=/data/feeds.opml
DB_PATH=/data/db/reader.db
CACHE_DIR=/cache

# Feed refresh schedule
OPML_SYNC_INTERVAL=3600      # seconds between OPML re-reads (default: 1h)
FEED_REFRESH_INTERVAL=900    # seconds between feed refresh cycles (default: 15m)

# Media cache
CACHE_MAX_ITEMS=500          # max number of cached media files
CACHE_MAX_AGE_HOURS=48       # max age of cached files in hours
KEEP_ITEMS=1000              # max items stored in DB
ITEMS_MAX_AGE_HOURS=168      # delete seen items older than this (hours); 168 = 7 days

# UI behaviour
PREFETCH_AHEAD=5             # items to pre-fetch ahead of current position
IMAGE_DISPLAY_DELAY_MS=5000  # dwell time per image in auto-scroll / slideshow (ms)
SLIDESHOW_TRANSITION_MS=400  # CSS crossfade duration between slideshow items (ms)

# Server
PORT=8080
LOG_LEVEL=info               # uvicorn log level: debug | info | warning | error
